# Slack bot token (xoxb-...). Create a Slack app, add the scopes listed in the
# README, install it to your workspace, and paste the Bot User OAuth Token here.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Channel ID for #daily-pet-memes (looks like C0XXXXXXXXX).
# In Slack, open the channel -> click the channel name -> "About" tab -> copy
# the Channel ID at the bottom.
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Timezone label used only for human-readable log lines (the actual schedule
# is owned by Render Cron Jobs). Defaults to America/Los_Angeles.
POST_TIMEZONE=America/Los_Angeles

# Giphy API key. Create one at https://developers.giphy.com/dashboard/.
CONTENT_API_KEY=your-giphy-api-key

# Optional: where to store the duplicate-prevention JSON file. Defaults to
# ./data/posted.json. On Render, set this to a path on a Persistent Disk
# (e.g. /var/data/posted.json) so memory of recent posts survives restarts.
POSTED_STORE_PATH=./data/posted.json

# Optional: how many recent Giphy IDs to remember when avoiding duplicates.
# Defaults to 200.
POSTED_HISTORY_SIZE=200
